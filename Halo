local CAM_CF = TAB2_CAM_CFRAME
local lockedFOV = 70
local BASE_ASPECT = 16 / 9

local function getAdjustedFOV(baseFOV)
    local vp = Camera.ViewportSize
    local aspect = vp.X / math.max(vp.Y, 1)
    local ratio = BASE_ASPECT / aspect
    local halfAngle = math.rad(baseFOV / 2)
    local adjustedHalf = math.atan(math.tan(halfAngle) * ratio)
    return math.clamp(math.deg(adjustedHalf) * 2, 30, 120)
end

RunService:BindToRenderStep("HaloHubCamLock", Enum.RenderPriority.Camera.Value + 1, function()
    if not camLocked then
