local TARGET_POSITION = Vector3.new(-347.666534, -7.490204, 26.719028)

local function isMyBase(plot)
    local sign = plot:FindFirstChild("PlotSign")
    if sign then
        local yb = sign:FindFirstChild("YourBase")
        if yb and yb:IsA("BillboardGui") and yb.Enabled then
            return true
        end
    end
    if plot:GetAttribute("Owner") == LocalPlayer.UserId then
        return true
    end
    return false
end

local function getNearestEnemyPlot()
    local closestPlot, closestDist = nil, math.huge
    for _, plot in ipairs(workspace.Plots:GetChildren()) do
        pcall(function()
            if isMyBase(plot) then
                return
            end
            local sign = plot:FindFirstChild("PlotSign")
            if not sign then
                return
            end
            local dist = (sign.Position - TARGET_POSITION).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestPlot = plot
            end
        end)
    end
    return closestPlot
end

-- ======================== BRAINROT NAME LOOKUP ========================
local STRUCTURAL_NAMES = {
    Base = true, Claim = true, PodiumModel = true, AnimalPodiums = true,
    PlotSign = true, Decorations = true, CashPad = true, Skin = true,
    Model = true, FriendPanel = true, Purchases = true, Unlock = true,
    InvisibleWalls = true, Laser = true, LaserHitbox = true, MainRoot = true,
    Spawn = true, DeliveryHitbox = true, Multiplier = true, AnimalTarget = true,
    StealHitbox = true, Slope = true
}

local function getBrainrotName(podium)
    if not podium then
        return nil
    end
    local base = podium:FindFirstChild("Base")
    local spawnPart = base and base:FindFirstChild("Spawn")
    if not spawnPart then
        return nil
    end
    local spawnPos = spawnPart.Position
    local plot = getNearestEnemyPlot()
    if not plot then
        return nil
    end
    local bestName, bestDist = nil, math.huge
    for _, child in ipairs(plot:GetChildren()) do
        if child:IsA("Model") and not STRUCTURAL_NAMES[child.Name] then
            local fakeRoot = child:FindFirstChild("FakeRootPart")
            if fakeRoot then
                local dist = (fakeRoot.Position - spawnPos).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestName = child.Name
                end
            end
        end
    end
    return (bestDist < 8) and bestName or nil
end

local function getBrainrotForSlot(slot)
    local plot = getNearestEnemyPlot()
    if not plot then
        return nil
    end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then
        return nil
    end
    local podium = podiums:FindFirstChild(tostring(slot))
    if not podium then
        return nil
    end
    return getBrainrotName(podium)
end

local function getGenerationForSlot(slot)
    local brName = getBrainrotForSlot(slot)
    if not brName then
        return nil
    end
    local debris = workspace:FindFirstChild("Debris")
    if not debris then
        return nil
    end
    for _, child in ipairs(debris:GetChildren()) do
        local overhead = child:FindFirstChild("AnimalOverhead")
        if overhead then
            local displayLabel = overhead:FindFirstChild("DisplayName")
            local genLabel = overhead:FindFirstChild("Generation")
            if displayLabel and displayLabel:IsA("TextLabel") and genLabel and genLabel:IsA("TextLabel") then
                if displayLabel.Text == brName then
                    return genLabel.Text
                end
            end
        end
    end
    return nil
end

local function getFakeRootForSlot(slot)
    local plot = getNearestEnemyPlot()
    if not plot then
        return nil
    end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then
        return nil
    end
    local podium = podiums:FindFirstChild(tostring(slot))
    if not podium then
        return nil
    end
    local base = podium:FindFirstChild("Base")
    local spawnPart = base and base:FindFirstChild("Spawn")
    if not spawnPart then
        return nil
    end
    local spawnPos = spawnPart.Position
    local bestFR, bestDist = nil, math.huge
    for _, child in ipairs(plot:GetChildren()) do
        if child:IsA("Model") and not STRUCTURAL_NAMES[child.Name] then
            local fakeRoot = child:FindFirstChild("FakeRootPart")
            if fakeRoot then
                local dist = (fakeRoot.Position - spawnPos).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestFR = fakeRoot
                end
            end
        end
    end
    return (bestDist < 8) and bestFR or nil
end

