local function fpsApplyToInstance(v)
    if v:IsA("MeshPart") then
        pcall(function()
            v.RenderFidelity = Enum.RenderFidelity.Automatic
        end)
    end
    if v:IsA("BasePart") then
        pcall(function()
            v.Material = Enum.Material.Plastic
        end)
        pcall(function()
            v.Reflectance = 0
        end)
        pcall(function()
            v.CastShadow = false
        end)
    elseif v:IsA("Decal") then
        v.Transparency = 1
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
        pcall(function()
            v.Lifetime = NumberRange.new(0)
        end)
        pcall(function()
            v.Enabled = false
        end)
    end
end

local function fpsApplyAll()
    local descendants = game:GetDescendants()
    for i, v in ipairs(descendants) do
        fpsApplyToInstance(v)
        if i % 100 == 0 then
            task.wait()
        end
    end
end

local function applyFPS()
    workspace.Terrain.WaterWaveSize = 0
    workspace.Terrain.WaterWaveSpeed = 0
    workspace.Terrain.WaterReflectance = 0
    workspace.Terrain.WaterTransparency = 0
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9
    Lighting.Brightness = 5
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    Lighting.ShadowSoftness = 0
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Sky") or v:IsA("Atmosphere") then
            if v:IsA("PostEffect") then
                local orig = v.Enabled
                table.insert(fpsRemovedConns, {obj = v, prop = "Enabled", orig = orig})
                v.Enabled = false
            else
                v.Parent = nil
                table.insert(fpsRemovedConns, {obj = v, orphan = true})
            end
        end
    end
    fpsDescConn = workspace.DescendantAdded:Connect(fpsApplyToInstance)
    task.spawn(fpsApplyAll)
    fpsShadowConn = RunService.Heartbeat:Connect(function()
        if Lighting.GlobalShadows then
            Lighting.GlobalShadows = false
        end
        if Lighting.ShadowSoftness ~= 0 then
            Lighting.ShadowSoftness = 0
        end
        if Lighting.EnvironmentDiffuseScale ~= 0 then
            Lighting.EnvironmentDiffuseScale = 0
        end
        if Lighting.EnvironmentSpecularScale ~= 0 then
            Lighting.EnvironmentSpecularScale = 0
        end
    end)
end

local function removeFPS()
    Lighting.GlobalShadows = origGlobalShadows
    Lighting.FogEnd = origFogEnd
    Lighting.FogStart = origFogStart
    Lighting.ShadowSoftness = origShadowSoftness
    Lighting.EnvironmentDiffuseScale = origEnvDiffScale
    Lighting.EnvironmentSpecularScale = origEnvSpecScale
    Lighting.Brightness = origBrightness2
    Lighting.ClockTime = origClockTime2
    Lighting.Ambient = origAmbient2
    Lighting.OutdoorAmbient = origOutdoorAmbient2
    workspace.Terrain.WaterWaveSize = origWaterWaveSize
    workspace.Terrain.WaterWaveSpeed = origWaterWaveSpeed
    workspace.Terrain.WaterReflectance = origWaterReflectance
    workspace.Terrain.WaterTransparency = origWaterTransparency
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    end)
    for _, ref in ipairs(fpsRemovedConns) do
        if ref.orphan then
            pcall(function()
                ref.obj.Parent = Lighting
            end)
        else
            pcall(function()
                ref.obj[ref.prop] = ref.orig
            end)
        end
    end
    fpsRemovedConns = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CastShadow = true
            if v:IsA("MeshPart") then
                pcall(function()
                    v.RenderFidelity = Enum.RenderFidelity.Automatic
                end)
            end
        elseif v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = true
        end
    end
    if fpsDescConn then
        fpsDescConn:Disconnect()
        fpsDescConn = nil
    end
    if fpsShadowConn then
        fpsShadowConn:Disconnect()
        fpsShadowConn = nil
    end
end
if FPS_ON then
    applyFPS()
end

