-- ======================== INSTANT FLASH ========================
local function doInstantFlash()
    if isTab2TPRunning then
        return
    end
    local podium = findTargetPodium()
    if not podium then
        return
    end
    local prompt = getOrCachePrompt(podium)
    if not prompt then
        return
    end
    if not ensureStealCallbacks(prompt) then
        return
    end
    isTab2TPRunning = true
    local tpPos = getTPForSlot(SELECTED_SLOT)
    local camCF, camFOV = getCamForSlot(SELECTED_SLOT)
    local function getChar()
        local c = LocalPlayer.Character
        if not c then
            return nil, nil, nil
        end
        return c, c:FindFirstChildOfClass("Humanoid"), c:FindFirstChild("HumanoidRootPart")
    end
    local c, hum, hrp = getChar()
    if not c or not hum or not hrp then
        isTab2TPRunning = false
        return
    end
    local carpet = LocalPlayer.Backpack:FindFirstChild(REQUIRED_TOOL) or c:FindFirstChild(REQUIRED_TOOL)
    if not carpet then
        for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if item:IsA("Tool") and (item.Name:lower():find("flying") or item.Name:lower():find("carpet")) then
                carpet = item
                break
            end
        end
    end
    if not carpet then
        isTab2TPRunning = false
        return
    end
    if carpet.Parent ~= c then
        hum:EquipTool(carpet)
        task.wait(0.09)
    end
    local c2, hum2, hrp2 = getChar()
    if not c2 or not hum2 or not hrp2 then
        isTab2TPRunning = false
        return
    end
    local spotB = (SELECTED_SLOT >= 1 and SELECTED_SLOT <= 4) and SPOT_B_1_4 or
        (SELECTED_SLOT == 5) and SPOT_B_5 or
        (SELECTED_SLOT == 6 or SELECTED_SLOT == 7) and SPOT_B_7 or
        SPOT_B_8_10
    hum2:ChangeState(Enum.HumanoidStateType.Physics)
    for _ = 1, 8 do
        hrp2.CFrame = spotB
        hrp2.AssemblyLinearVelocity = Vector3.zero
        hrp2.AssemblyAngularVelocity = Vector3.zero
        task.wait(0.03)
    end
    hrp2.AssemblyLinearVelocity = Vector3.zero
    hrp2.AssemblyAngularVelocity = Vector3.zero
    task.wait(0.05)
    lockCamera(camCF, camFOV)
    local c3, hum3, hrp3 = getChar()
    if not c3 or not hum3 or not hrp3 then
        unlockCamera()
        isTab2TPRunning = false
        return
    end
    local flashTool = nil
    for _ = 1, 3 do
        flashTool = LocalPlayer.Backpack:FindFirstChild(FLASH_TOOL) or c3:FindFirstChild(FLASH_TOOL)
        if not flashTool then
            task.wait(0.1)
        else
            if flashTool.Parent ~= c3 then
                hum3:EquipTool(flashTool)
                local t = tick()
                repeat
                    task.wait(0.03)
                until flashTool.Parent == c3 or tick() - t > 1
            end
            if flashTool.Parent == c3 then
                break
            end
            flashTool = nil
        end
    end
    if not flashTool then
        unlockCamera()
        isTab2TPRunning = false
        return
    end
    hrp3.CFrame = CFrame.new(tpPos)
    hrp3.AssemblyLinearVelocity = Vector3.zero
    hrp3.AssemblyAngularVelocity = Vector3.zero
    if AUTO_BLOCK then
        local bt = findNearestEnemy()
        if bt then
            task.spawn(function()
                NavigationBlock(bt)
            end)
            RunService.RenderStepped:Wait()
            RunService.RenderStepped:Wait()
        end
    end
    if AUTO_BALLOON and adminRemote then
        local balloonTarget = findNearestEnemy()
        if balloonTarget then
            local cmdToSend = BALLOON_CMD
            task.delay(0.09, function()
                sendAdminCmd(balloonTarget, cmdToSend)
            end)
        end
    end
    flashTool:Activate()
    unlockCamera()
    local rc = LocalPlayer.Character
    local rh = rc and rc:FindFirstChildOfClass("Humanoid")
    if rh then
        rh:ChangeState(Enum.HumanoidStateType.Running)
    end
    task.wait(STEAL_DELAY)
    local freshPodium = findTargetPodium()
    if freshPodium then
        local fp = getOrCachePrompt(freshPodium)
        if fp and InternalStealCache[fp] then
            executeSteal(fp)
        end
    end
    task.wait(1)
    isTab2TPRunning = false
end

