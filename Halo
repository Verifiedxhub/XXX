local function getOrCachePrompt(podium)
    local uid = podium:GetFullName()
    local cached = PromptMemoryCache[uid]
    if cached and cached.Parent then
        return cached
    end
    local prompt = getPromptFromPodium(podium)
    if not prompt then
        return nil
    end
    if not originalDurations[prompt] then
        originalDurations[prompt] = prompt.HoldDuration
    end
    prompt.HoldDuration = 0
    PromptMemoryCache[uid] = prompt
    ensureStealCallbacks(prompt)
    return prompt
end

