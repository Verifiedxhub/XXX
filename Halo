local adminRemote = nil
local adminUUID = "f888ee6e-c86d-46e1-93d7-0639d6635d42"
local adminIsFunction = false

local function setRemote(remote, method)
    adminRemote = remote
    adminIsFunction = (remote:IsA("RemoteFunction") or method == "InvokeServer")
end

task.spawn(function()
    local Packages = ReplicatedStorage:FindFirstChild("Packages")
    if Packages then
        local Net = Packages:FindFirstChild("Net")
        if Net then
            local children = Net:GetChildren()
            for i, obj in ipairs(children) do
                if obj.Name == "RE/AdminPanelService/OpenUI" then
                    for offset = 3, 1, -1 do
                        local candidate = children[i + offset]
                        if candidate and candidate:IsA("RemoteFunction") and candidate.Name:sub(1, 3) == "RF/" then
                            setRemote(candidate, "InvokeServer")
                            return
                        end
                    end
                    break
                end
            end
        end
    end

    local oldNC
    oldNC = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "InvokeServer" or method == "FireServer" then
            local a = {...}
            if a[1] and type(a[1]) == "string" and #a[1] == 36 and a[1]:sub(1, 4) == "f888" then
                if not adminRemote then
                    setRemote(self, method)
                end
            end
        end
        return oldNC(self, ...)
    end)
end)

local function sendAdminCmd(player, cmd)
    if not adminRemote or not adminUUID or not player then return end
    pcall(function()
        if adminIsFunction then
            adminRemote:InvokeServer(adminUUID, player, cmd)
        else
            adminRemote:FireServer(adminUUID, player, cmd)
        end
    end)
end

