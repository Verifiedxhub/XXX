    local function getInputPos(input)
        return Vector2.new(input.Position.X, input.Position.Y)
    end
    local function isPress(input)
        return input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch
    end
    local function isMove(input)
        return input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch
    end
    local function startDrag(btn, key, input, clickFn, bgClr)
        gDrag.btn = btn
        gDrag.key = key
        gDrag.start = getInputPos(input)
        gDrag.pos = Vector2.new(btn.Position.X.Offset, btn.Position.Y.Offset)
        gDrag.moved = false
        gDrag.click = clickFn
        gDrag.bg = bgClr
        TS:Create(btn, TweenInfo.new(0.07), {BackgroundColor3 = Color3.fromRGB(232, 220, 175)}):Play()
    end
    local function finishDrag()
        local btn = gDrag.btn
        local key = gDrag.key
        local fn = gDrag.click
        local moved = gDrag.moved
        local bg = gDrag.bg
        gDrag.btn = nil
        gDrag.key = nil
        gDrag.start = nil
        gDrag.pos = nil
        gDrag.moved = false
        gDrag.click = nil
        gDrag.bg = nil
        if btn then
            TS:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = bg or Color3.fromRGB(248, 240, 205)}):Play()
            if moved then
                FDEF[key].x = btn.Position.X.Offset
                FDEF[key].y = btn.Position.Y.Offset
                svFloat()
            else
                if fn then
                    fn()
                end
            end
        end
    end
    UIS.InputChanged:Connect(function(input)
