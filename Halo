        if FLOAT_LOCKED then
            return
        end
        if not isMove(input) then
            return
        end
        local d = getInputPos(input) - gDrag.start
        if d.Magnitude > 4 then
            gDrag.moved = true
            gDrag.btn.Position = UDim2.fromOffset(gDrag.pos.X + d.X, gDrag.pos.Y + d.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input)
